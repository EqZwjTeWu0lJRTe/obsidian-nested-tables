{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": true,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"moduleResolution": "node",
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"useUnknownInCatchVariables": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"lib": [
			"DOM",
			"ES2020"
		]
	},
	"include": [
		"src/**/*.ts"
	]
}
